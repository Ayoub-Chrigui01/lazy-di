{
  "name": "@chrigui/lazy-di",
  "version": "0.1.9",
  "description": "Zero-ceremony dependency injection for TypeScript",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest",
    "coverage": "vitest run --coverage"
  },
  "peerDependencies": {
    "reflect-metadata": ">=0.1.13"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Ayoub-Chrigui01/lazy-di"
  },
  "homepage": "https://github.com/Ayoub-Chrigui01/lazy-di#readme",
  "keywords": [],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@vitest/coverage-v8": "^4.1.5",
    "reflect-metadata": "^0.2.2",
    "tsup": "^8.5.1",
    "typescript": "^6.0.2",
    "vitest": "^4.1.4"
  },
  "dependencies": {
    "tinyglobby": "^0.2.16"
  }
}
